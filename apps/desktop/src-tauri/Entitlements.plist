<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT compilation for the WebView -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (needed by V8/WebView) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow dynamic code generation for embedded-postgres and Node.js -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network client access for localhost communication -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Network server access for the sidecar process -->
    <key>com.apple.security.network.server</key>
    <true/>
</dict>
</plist>
